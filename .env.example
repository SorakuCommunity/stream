# ============================================================
# SORAKU STREAM — Environment Variables
# Salin ke .env.local dan isi nilainya
# ============================================================

# --- AniList OAuth ---
# Daftar developer: https://anilist.co/settings/developer
NEXT_PUBLIC_ANILIST_CLIENT_ID="anilist_client_id"
ANILIST_CLIENT_SECRET="anilist_client_secret"
NEXT_PUBLIC_ANILIST_REDIRECT_URI="http://localhost:3000/auth/callback"

# --- Supabase (Discord + Email Auth) ---
# Dashboard: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://hgxvsllcwqhcehkbikis.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# --- Database (Prisma) ---
# Transaction Pooler — untuk Vercel/production (port 6543)
DATABASE_URL="postgresql://postgres.hgxvsllcwqhcehkbikis:PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct Connection — hanya untuk prisma migrate / db push (port 5432)
DIRECT_URL="postgresql://postgres:PASSWORD@db.hgxvsllcwqhcehkbikis.supabase.co:5432/postgres"

# --- Consumet API (Video Source — Self-host di Vercel) ---
# Deploy: https://github.com/consumet/api.consumet.org → Deploy to Vercel
NEXT_PUBLIC_CONSUMET_API_URL="https://your-consumet.vercel.app"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
